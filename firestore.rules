rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: look up a user's Firebase Auth uid from the users collection.
    // Used to enforce owner-only access on personal data collections.
    function ownerUid(mobile) {
      return get(/databases/$(database)/documents/users/$(mobile)).data.uid;
    }

    // Users — any authenticated user can read and write
    match /users/{mobile} {
      allow read, write: if request.auth != null;
    }

    // User tab configs — owner can read/write their own tab flags.
    // `accessManageTabs` is admin-controlled and must not be changed by clients.
    match /user-tab-configs/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && !('accessManageTabs' in request.resource.data);
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && (
                      !('accessManageTabs' in request.resource.data)
                      || (
                        'accessManageTabs' in resource.data
                        && request.resource.data.accessManageTabs == resource.data.accessManageTabs
                      )
                    );
      allow delete: if false;
    }

    // Groups — any authenticated user can read and write (all subcollections)
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    match /groups/{groupId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Shared expenses — any authenticated user (includes /months/.../payments/... subcollections)
    match /shared-expenses/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Shared expenses backup — any authenticated user
    match /shared-expenses-backup/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Shared loans — any authenticated user (includes /months/.../loans/... subcollections)
    match /shared-loans/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Personal expenses — read restricted to owner; write open to any authenticated user
    // NOTE: write must remain open to all authenticated users because shared-expense
    // creation cross-posts a record to the payer's personal-expenses (see saveData in
    // firebase-apis.js).  Consider moving the cross-posting to a Cloud Function so
    // this rule can be tightened to owner-only writes in the future.
    // The parent document (personal-expenses/{mobile}) is also accessed:
    //   - read: fetchMonths in personal-expense-list.js reads months[] from the parent doc
    //   - write: saveData tracks months via arrayUnion on the parent doc (cross-poster writes)
    match /personal-expenses/{mobile} {
      allow read: if request.auth != null && request.auth.uid == ownerUid(mobile);
      allow write: if request.auth != null;
    }
    match /personal-expenses/{mobile}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == ownerUid(mobile);
      allow write: if request.auth != null;
    }

    // Personal loans — owner only
    // The parent document (personal-loans/{mobile}) is also accessed:
    //   - read: fetchMonths reads months[] from the parent doc
    //   - write: saveData tracks months via arrayUnion on the parent doc
    match /personal-loans/{mobile} {
      allow read, write: if request.auth != null && request.auth.uid == ownerUid(mobile);
    }
    match /personal-loans/{mobile}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == ownerUid(mobile);
    }

    // Salaries — owner only
    match /salaries/{mobile}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == ownerUid(mobile);
    }

    // Bug reports — authenticated users can read/write their own only
    match /bug-reports/{mobileKey}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Collection group rule required for collectionGroup('reports') admin query
    match /{path=**}/reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    // Collection group rules for leave-group balance checks
    match /{path=**}/payments/{paymentId} {
      allow read: if request.auth != null;
    }
    match /{path=**}/loans/{loanId} {
      allow read: if request.auth != null;
    }

    // Bug report counters (global sequence number) — authenticated users only.
    // NOTE: A Cloud Function for the counter increment would allow fully locking this rule
    //       to server-side access only, which is the recommended long-term fix.
    match /bug-report-counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    // Bug report notifications (admin inbox + per-user inboxes) — authenticated only
    match /bug-report-notifications/{target}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // App config — read-only for any authenticated user; written via Admin Console only
    match /configs/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
