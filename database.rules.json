{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },

    "groups": {
      ".read": "auth !== null",
      ".write": "auth !== null",
      "$groupId": {
        ".validate": "newData.hasChildren(['name'])"
      }
    },

    "shared-expenses": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },

    "shared-expenses-backup": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },

    "shared-loans": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },

    "personal-expenses": {
      "$mobile": {
        ".read": "auth !== null && root.child('users').child($mobile).child('uid').val() === auth.uid",
        ".write": "auth !== null"
      }
    },

    "personal-loans": {
      "$mobile": {
        ".read": "auth !== null && root.child('users').child($mobile).child('uid').val() === auth.uid",
        ".write": "auth !== null && root.child('users').child($mobile).child('uid').val() === auth.uid"
      }
    },

    "salaries": {
      "$mobile": {
        ".read": "auth !== null && root.child('users').child($mobile).child('uid').val() === auth.uid",
        ".write": "auth !== null && root.child('users').child($mobile).child('uid').val() === auth.uid"
      }
    },
    "bug-reports": {
      ".read": "auth != null",
      ".write": true
    },
    "bug-report-counters": {
      ".read": true,
      ".write": true,
      "global": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "bug-report-notifications": {
      "admin": {
        ".read": "auth != null",
        ".write": true
      },
      "$mobile": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
